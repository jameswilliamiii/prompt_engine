<%# Prism.js for syntax highlighting - only loaded on this page %>
<link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />

<div class="admin-header">
  <div>
    <h1>Version <%= @version.version_number %></h1>
    <p class="text-muted"><%= @prompt.name %></p>
  </div>
  <div class="btn-group">
    <%= link_to "Test Run History", prompt_version_playground_run_results_path(@prompt, @version), class: "btn btn--secondary btn--medium" %>
    <%= link_to "Back to History", prompt_versions_path(@prompt), class: "btn btn--secondary btn--medium" %>
    <%= link_to "Back to Prompt", @prompt, class: "btn btn--secondary btn--medium" %>
    <% unless @version.version_number == @prompt.versions.maximum(:version_number) %>
      <%= button_to "Restore This Version", restore_prompt_version_path(@prompt, @version), 
          method: :post, 
          class: "btn btn--primary btn--medium",
          data: { turbo_confirm: "Are you sure you want to restore this version?" } %>
    <% end %>
  </div>
</div>

<div class="prompt-details">
  <div class="card mb-lg">
    <div class="card__header">
      <h3 class="card__title">Version Information</h3>
    </div>
    <div class="card__body">
      <div class="detail-grid">
        <div class="detail-item">
          <label class="detail-label">Version Number</label>
          <div class="detail-value"><%= @version.version_number %></div>
        </div>
        
        <div class="detail-item">
          <label class="detail-label">Created At</label>
          <div class="detail-value"><%= @version.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
        </div>
        
        <div class="detail-item">
          <label class="detail-label">Change Description</label>
          <div class="detail-value">
            <%= @version.change_description.presence || content_tag(:em, "No summary provided", class: "text-muted") %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-lg">
    <div class="card__header">
      <h3 class="card__title">Prompt Content</h3>
    </div>
    <div class="card__body">
      <% if @version.content.present? %>
        <pre class="prompt-content"><%= @version.content %></pre>
      <% else %>
        <p class="text-muted">No content provided</p>
      <% end %>
    </div>
  </div>

  <div class="card mb-lg">
    <div class="card__header">
      <h3 class="card__title">System Message</h3>
    </div>
    <div class="card__body">
      <% if @version.system_message.present? %>
        <pre class="prompt-content"><%= @version.system_message %></pre>
      <% else %>
        <p class="text-muted">No system message provided</p>
      <% end %>
    </div>
  </div>

  <div class="card mb-lg">
    <div class="card__header">
      <h3 class="card__title">Model Settings</h3>
    </div>
    <div class="card__body">
      <div class="detail-grid">
        <div class="detail-item">
          <label class="detail-label">Model</label>
          <div class="detail-value"><%= @version.model %></div>
        </div>
        
        <div class="detail-item">
          <label class="detail-label">Temperature</label>
          <div class="detail-value"><%= @version.temperature %></div>
        </div>
        
        <div class="detail-item">
          <label class="detail-label">Max Tokens</label>
          <div class="detail-value"><%= @version.max_tokens || "Default" %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="form__actions mt-lg">
  <%= link_to "Back to Version History", prompt_versions_path(@prompt), class: "btn btn--secondary btn--medium" %>
</div>

<%# Prism.js JavaScript - loaded at the end of the page %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-ruby.min.js"></script>